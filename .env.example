# ============================================================
# A股交易决策辅助系统 - 环境变量配置
# ============================================================
# 复制此文件为 .env 并修改对应值

# ---------- 数据源配置 ----------
# 数据源优先级，逗号分隔，按顺序尝试
DATA_SOURCES=efinance,akshare,baostock

# Tushare Pro Token (可选，注册 https://tushare.pro 获取)
TUSHARE_TOKEN=

# ---------- 自选股 ----------
# 关注的股票代码，逗号分隔 (沪深A股)
WATCH_LIST=000001,600519,300750,002594,601318

# ---------- AI 决策辅助 ----------
# LLM 提供商: deepseek / openai / ollama / 留空则不使用AI分析
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# ---------- 通知渠道 ----------
# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 企业微信 Webhook
WECHAT_WEBHOOK_URL=

# 邮件通知
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# ---------- 分析参数 ----------
# 历史数据天数
HISTORY_DAYS=120
# 分析报告格式: markdown / json
REPORT_FORMAT=markdown
# 报告输出目录
REPORT_DIR=reports
# 数据缓存目录
DATA_DIR=data

# ---------- 日志 ----------
LOG_LEVEL=INFO
LOG_FILE=logs/a-stock-advisor.log
